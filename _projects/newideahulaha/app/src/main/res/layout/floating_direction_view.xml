<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_floating_panel"
    android:elevation="12dp"
    android:clipToOutline="true">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp"
        android:background="#00000000">

        <!-- 顶部：关闭 + 坐标 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_close"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_close"
                android:background="@android:color/transparent"
                android:contentDescription="关闭"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tv_coord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="10sp"
                android:textColor="#CCCCCC"
                android:gravity="center"
                android:text="未启动" />

        </LinearLayout>

        <!-- 分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#55FFFFFF"
            android:layout_marginVertical="6dp" />

        <!-- 上 -->
        <ImageButton
            android:id="@+id/btn_up"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_arrow_up"
            android:background="@drawable/bg_circle_button"
            android:contentDescription="上移"
            android:padding="12dp" />

        <!-- 左右 + 保存 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginVertical="6dp">

            <ImageButton
                android:id="@+id/btn_left"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_arrow_left"
                android:background="@drawable/bg_circle_button"
                android:contentDescription="左移"
                android:padding="12dp"
                android:layout_marginEnd="10dp" />

            <ImageButton
                android:id="@+id/btn_save"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/ic_save"
                android:background="@drawable/bg_circle_button_save"
                android:contentDescription="保存坐标"
                android:padding="14dp"
                android:elevation="4dp" />

            <ImageButton
                android:id="@+id/btn_right"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_arrow_right"
                android:background="@drawable/bg_circle_button"
                android:contentDescription="右移"
                android:padding="12dp"
                android:layout_marginStart="10dp" />

        </LinearLayout>

        <!-- 下 -->
        <ImageButton
            android:id="@+id/btn_down"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_arrow_down"
            android:background="@drawable/bg_circle_button"
            android:contentDescription="下移"
            android:padding="12dp" />

        <!-- 步长选择：50m / 500m / 5km / 30km -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginVertical="6dp">

            <TextView
                android:id="@+id/btn_step_0"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:text="50m"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:background="@drawable/bg_circle_button"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="3dp" />

            <TextView
                android:id="@+id/btn_step_1"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:text="500m"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:background="@drawable/bg_circle_button"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginHorizontal="3dp" />

            <TextView
                android:id="@+id/btn_step_2"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:text="5km"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:background="@drawable/bg_circle_button"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginHorizontal="3dp" />

            <TextView
                android:id="@+id/btn_step_3"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1"
                android:text="30km"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:gravity="center"
                android:background="@drawable/bg_circle_button"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="3dp" />

        </LinearLayout>

        <!-- 底部分割线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#55FFFFFF"
            android:layout_marginVertical="6dp" />

        <!-- 打开百度地图（文字按钮） -->
        <TextView
            android:id="@+id/btn_open_baidu"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="打开百度地图"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/bg_circle_button"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
